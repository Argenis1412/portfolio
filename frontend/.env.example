# Frontend Environment Variables Template
# Copy this file to .env.local for local development.

# URL para a API do backend (FastAPI)
# Exemplo Dev: http://localhost:8000/api/v1
# Exemplo Prod: https://selected-fionna-argenis1412-58caae17.koyeb.app/api/v1 (Documentação em /docs)
VITE_API_URL=http://localhost:8000/api/v1

# Sentry DSN para acompanhamento de erros no Frontend.
# Substitua pelo seu DSN do Sentry (Projeto Frontend/React)
VITE_SENTRY_DSN=
