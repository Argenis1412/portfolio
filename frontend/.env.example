# Frontend Environment Variables Template
# Copy this file to .env.local for local development.

# URL para a API do backend (FastAPI)
# Exemplo Dev: http://localhost:8000/api/v1
# Exemplo Prod: https://sua-api.koyeb.app/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# Sentry DSN para acompanhamento de erros no Frontend.
# Substitua pela seu DSN do Sentry (Proyecto Frontend/React)
VITE_SENTRY_DSN=
