NOME_APP="Portfólio Backend API"
AMBIENTE="local"
ORIGENS_PERMITIDAS="http://localhost:5173,http://127.0.0.1:5173"
FORMSPREE_URL="https://formspree.io/f"
FORMSPREE_FORM_ID=""
DATABASE_URL="sqlite+aiosqlite:///./portfolio.db"

# --- Observabilidade ---
# DSN (Chave) do Sentry. Deixar vazio desativa o Sentry.
SENTRY_DSN=""
# Amostragem de rastreamento (0.0 a 1.0). 1.0 é 100%.
SENTRY_TRACES_SAMPLE_RATE=0.2
# OTLP Endpoint (Opcional, para Jaeger ou Grafana Tempo). Não use o Sentry aqui.
OTLP_ENDPOINT=""

# Regex para permitir subdomínios da Vercel no CORS (Branch Previews)
REGEX_ORIGENS_PERMITIDAS=^https://portfolio.*-argenis1412s-projects\.vercel\.app$
