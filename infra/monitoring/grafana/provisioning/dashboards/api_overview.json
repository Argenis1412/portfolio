{
  "title": "Portfólio API — Overview",
  "uid": "portfolio-api-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"portafolio-api\"}[1m]))",
        "legendFormat": "req/s"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 10 },
        { "color": "red", "value": 50 }
      ]}}}
    },
    {
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"portafolio-api\",status=\"5xx\"}[1m])) or vector(0)",
        "legendFormat": "errors/s"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "red", "value": 0.01 }
      ]}}}
    },
    {
      "id": 3,
      "title": "Latência P95 (ms)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"portafolio-api\"}[5m])) by (le)) * 1000",
        "legendFormat": "P95"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 200 },
        { "color": "red", "value": 500 }
      ]}}}
    },
    {
      "id": 4,
      "title": "Latência P99 (ms)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"portafolio-api\"}[5m])) by (le)) * 1000",
        "legendFormat": "P99"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "yellow", "value": 500 },
        { "color": "red", "value": 1000 }
      ]}}}
    },
    {
      "id": 5,
      "title": "Requests por Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (handler) (rate(http_requests_total{job=\"portafolio-api\"}[1m]))",
        "legendFormat": "{{handler}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "title": "Distribuição de Latência (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"portafolio-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"portafolio-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"portafolio-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "HTTP Status Codes",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (status) (increase(http_requests_total{job=\"portafolio-api\"}[1h]))",
        "legendFormat": "{{status}}"
      }]
    }
  ]
}
